{
  "name": "kvarn",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.6",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@kvarn/web",
    "dev:worker": "turbo run dev --filter=@kvarn/worker",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @kvarn/db generate",
    "db:migrate:local": "pnpm --filter @kvarn/worker db:migrate:local"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.15.0",
    "wrangler": "^4.107.0"
  }
}
